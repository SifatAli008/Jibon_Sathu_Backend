# Port 5433 = docker-compose host port (see README). Use 127.0.0.1 to avoid ::1 hitting another Postgres.
DATABASE_URL=postgresql+asyncpg://jibon:jibon@127.0.0.1:5433/jibon_sathu
# Reject report timestamps more than this many seconds after server UTC (clock skew policy).
MAX_FUTURE_SKEW_SECONDS=300
MAX_SYNC_BATCH_ITEMS=500
# Issue #7: set true in production; requires provisioned gateway secrets (see SECURITY_MODEL.md)
# REQUIRE_GATEWAY_AUTH=false
# Issue #8: slowapi limit string (per X-Gateway-Id)
# SYNC_RATE_LIMIT=120/minute
# Issue #8: enable GET /v1/sync/conflicts (dashboard: X-Sync-Admin-Key)
# SYNC_ADMIN_KEY=local-dev-sync-admin-key
# Dev-only GET /reports (dashboard: X-Dev-Reports-Key; exposes source_gateway_id)
# REPORTS_DEV_KEY=local-dev-reports-key
MODEL_ARTIFACTS_BASE_DIR=artifacts/models
# Optional: require X-Model-Download-Key for GET /models/.../latest/file
# MODELS_DOWNLOAD_KEY=
# Optional: enable POST /models/.../publish with X-Models-Admin-Key
# MODELS_ADMIN_KEY=

# --- Issue #11 (Celery M6 triage) — Redis broker; worker: celery -A app.worker worker -l info
# CELERY_BROKER_URL=redis://127.0.0.1:6379/0
# Optional separate result backend (defaults to broker)
# CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
# Tests / inline triage without Redis (uses in-memory broker in app.worker)
# CELERY_TASK_ALWAYS_EAGER=false

# --- Issue #12 (gRPC SyncIngest) — in-process server; 0 = disabled (tests default to 0)
# GRPC_PORT=50051
# Metadata x-client-version must be >= this semver
# GRPC_MIN_CLIENT_VERSION=1.0.0

# --- Issue #13 (dashboard read API) — set to require X-Dashboard-Admin-Key on GET /v1/analytics/*
# DASHBOARD_ADMIN_KEY=
# ANALYTICS_CACHE_TTL_SECONDS=30
