# Port 5433 = docker-compose host port (see README). Use 127.0.0.1 to avoid ::1 hitting another Postgres.
DATABASE_URL=postgresql+asyncpg://jibon:jibon@127.0.0.1:5433/jibon_sathu
# Reject report timestamps more than this many seconds after server UTC (clock skew policy).
MAX_FUTURE_SKEW_SECONDS=300
MAX_SYNC_BATCH_ITEMS=500
# Issue #7: set true in production; requires provisioned gateway secrets (see SECURITY_MODEL.md)
# REQUIRE_GATEWAY_AUTH=false
# Issue #8: slowapi limit string (per X-Gateway-Id)
# SYNC_RATE_LIMIT=120/minute
# Issue #8: enable GET /sync/conflicts
# SYNC_ADMIN_KEY=
# Optional: enable GET /reports with header X-Dev-Reports-Key: <same value>
# REPORTS_DEV_KEY=change-me-in-local-dev-only
MODEL_ARTIFACTS_BASE_DIR=artifacts/models
# Optional: require X-Model-Download-Key for GET /models/.../latest/file
# MODELS_DOWNLOAD_KEY=
# Optional: enable POST /models/.../publish with X-Models-Admin-Key
# MODELS_ADMIN_KEY=
